# Copy this file to .env in the repo root and fill in real values.
# This covers the CV pipeline / training tooling. For the webapp backend's
# own settings (LLM provider, Redis, CORS, database), see webapp/.env.example.

# --- Fine-tuning (scripts/finetune_model.py) ---
# Get your own free key at https://roboflow.com -- do NOT reuse the API key
# hardcoded in training_notebooks/basketball_player_detection_training.ipynb
# (sEx489KMvifSEAxAfJnz). That key belongs to the original tutorial author,
# not you, and is only left in place there as a historical/reference artifact.
ROBOFLOW_API_KEY=your_own_key_here

# --- Model resolution overrides (pipeline/model_resolution.py) ---
# Optional. Force a specific weights file regardless of what's in models/ or
# whether the COCO fallback would otherwise be used. Mainly useful for testing
# the fallback path on purpose, or pointing at a fine-tuned run's output
# (e.g. models/finetuned/<run_name>/weights/best.pt) without using --adopt.
# PLAYER_DETECTOR_PATH_OVERRIDE=
# BALL_DETECTOR_PATH_OVERRIDE=
# COURT_KEYPOINT_DETECTOR_PATH_OVERRIDE=
