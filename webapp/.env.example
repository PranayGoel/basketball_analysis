# Copy this file to webapp/backend/.env and fill in real values.
# Every var here maps 1:1 to app/config.py's Settings fields.

# --- LLM (narrative generation, single-game Q&A, library-wide search) ---
# Passed straight through to llm_client.get_client() -- see that module for
# the full list of supported providers and their default models/base URLs.
LLM_PROVIDER=openai
LLM_API_KEY=sk-...
LLM_MODEL=
LLM_BASE_URL=

# --- Infra ---
REDIS_URL=redis://localhost:6379

# --- Upload limit (MB) ---
# Requests larger than this are rejected with HTTP 413 before touching disk.
MAX_UPLOAD_SIZE_MB=500

# --- CORS ---
# Comma-separated list of origins allowed to call the API. Defaults to the
# Vite dev server's default port if unset.
CORS_ORIGINS=http://localhost:5173

# --- Database ---
# Leave unset to default to sqlite:///<DATA_DIR>/app.db. Only set this to
# point at a different database entirely (e.g. a non-default location).
# DATABASE_URL=
